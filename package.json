{
  "name": "vicflex-bracket-filter",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "description": "Portable Bracket Filter for VicFlex Bracket Configurations using Next.js and Electron.",
  "author": "Chenla Long, Jr",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "make": "npm run build && electron-forge make",
    "package": "npm run build && electron-forge package",
    "start": "electron .",
    "release": "ts-node --transpile-only --project tools/tsconfig.tools.json tools/release.ts",
    "clean": "node -e \"require('fs').rmSync('out',{recursive:true,force:true}); require('fs').rmSync('build',{recursive:true,force:true});\""
  },
  "dependencies": {
    "axios": "^1.9.0",
    "electron-squirrel-startup": "^1.0.1",
    "exceljs": "^4.4.0",
    "next": "^15.4.0-canary.67",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "serve": "^14.2.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-deb": "^7.8.1",
    "@electron-forge/maker-rpm": "^7.8.1",
    "@electron-forge/maker-squirrel": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.1",
    "@electron-forge/plugin-fuses": "^7.8.1",
    "@electron/fuses": "^1.8.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "36.3.2",
    "fs-extra": "^11.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
